# Normalize line endings to LF in the repo, auto-convert on checkout
* text=auto eol=lf

# Ensure these are always LF
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.svg text eol=lf

# Binary files
*.png binary
*.jpg binary
*.pdf binary
*.woff2 binary
